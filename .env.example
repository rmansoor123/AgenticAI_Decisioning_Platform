# ============================================================
# Fraud Detection Platform — Environment Variables
# ============================================================
# Copy to .env and adjust values as needed.
# All defaults match existing behavior (SQLite + in-memory).
# Set backends to upgrade individual layers.

# --- Database ---
DB_BACKEND=sqlite                                              # postgres | sqlite
POSTGRES_URL=postgresql://fraud_user:fraud_pass@localhost:5432/fraud_detection
DB_PATH=./data/fraud_detection.db                              # SQLite fallback path

# --- Cache + Messaging ---
CACHE_BACKEND=memory                                           # redis | memory
REDIS_URL=redis://localhost:6380

# --- Vector Search ---
VECTOR_BACKEND=pinecone                                        # pinecone | qdrant | chromadb | weaviate
QDRANT_URL=http://localhost:6333
CHROMADB_URL=http://localhost:8100
WEAVIATE_URL=http://localhost:8081
EMBEDDING_MODEL=all-MiniLM-L6-v2
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# --- Graph ---
GRAPH_BACKEND=memory                                           # neo4j | memory
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fraud_detection

# --- Analytics ---
ANALYTICS_BACKEND=sqlite                                           # pinot | sqlite
PINOT_BROKER_URL=http://localhost:8099
PINOT_CONTROLLER_URL=http://localhost:9000

# --- Observability ---
OBSERVABILITY_BACKEND=sqlite                                   # langfuse | phoenix | sqlite
LANGFUSE_HOST=http://localhost:3100
PHOENIX_URL=http://localhost:6006
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Memory ---
MEMORY_BACKEND=sqlite                                          # letta | mem0 | sqlite
MEM0_VECTOR_STORE=qdrant

# --- Letta (Memory) ---
LETTA_BASE_URL=http://localhost:8283
LETTA_API_KEY=

# --- Zep (Temporal Memory) ---
TEMPORAL_BACKEND=none                                          # zep | memory | none
ZEP_API_URL=http://localhost:8200
ZEP_API_KEY=

# --- API Mode ---
API_MODE=free                                                  # free | simulation | real

# --- Free APIs (no credit card required) ---
EMAILREP_API_KEY=                                              # emailrep.io — 1,000/day
ABUSEIPDB_API_KEY=                                             # abuseipdb.com — 1,000/day
OPENCORPORATES_API_KEY=                                        # opencorporates.com — 50/day
VIRUSTOTAL_API_KEY=                                            # virustotal.com — 500/day
ABSTRACT_EMAIL_API_KEY=                                        # abstractapi.com — 100/month
# No key needed: ip-api.com, Nominatim/OSM, stopforumspam, OFAC SDN, ABA checksum

# ─── LLM Provider (default: ollama — free, local, no token costs) ───────────
USE_LLM=true
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
# Use http://ollama:11434/v1 if running Node server inside Docker

# ─── OpenAI (dormant — set LLM_PROVIDER=openai to activate) ─────────────────
OPENAI_API_KEY=your_openai_key_here

# ─── Anthropic (dormant — set LLM_PROVIDER=anthropic to activate) ────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Eval Service ---
EVAL_SERVICE_URL=http://localhost:8000

# --- BrainTrust (Experiments) ---
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=fraud-detection

# --- Server ---
PORT=3001
